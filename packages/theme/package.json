{
  "name": "@hoverkraft/docusaurus-theme",
  "version": "1.0.0",
  "description": "Hoverkraft theme for Docusaurus",
  "main": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./components": {
      "types": "./lib/components.d.ts",
      "import": "./lib/components.js",
      "require": "./lib/components.js",
      "default": "./lib/components.js"
    }
  },
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "prebuild": "rimraf lib",
    "build": "tsc && node scripts/copy-static-assets.js",
    "start": "tsc --watch",
    "format": "biome format --write .",
    "check": "biome check --error-on-warnings --write .",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "npm run lint -- --fix",
    "lint:ci": "biome lint --error-on-warnings . --reporter=sarif | tee biome-report.sarif",
    "vitest": "vitest",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "docusaurus",
    "theme",
    "hoverkraft",
    "documentation"
  ],
  "author": "Hoverkraft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoverkraft-tech/docusaurus-theme.git"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/theme-common": "^3.0.0",
    "@docusaurus/types": "^3.0.0",
    "@docusaurus/utils": "^3.0.0",
    "@docusaurus/utils-validation": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/theme-common": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@docusaurus/utils": "^3.10.1",
    "@docusaurus/utils-validation": "^3.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "identity-obj-proxy": "^3.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "^@docusaurus/Link$": "<rootDir>/src/test-utils/docusaurusLinkMock.tsx",
      "^@docusaurus/useBaseUrl$": "<rootDir>/src/test-utils/docusaurusUseBaseUrlMock.ts"
    },
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test)?(.*).+(ts|tsx|js)"
    ],
    "collectCoverageFrom": [
      "**/src/**/*.[jt]s?(x)"
    ]
  }
}
